{
  "name": "stride-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "@react-native-async-storage/async-storage": "2.2.0"
  },
  "scripts": {
