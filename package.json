  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-restart": "^0.0.27"
  },
  "devDependencies": {
    "patch-package": "^8.0.0",
    "turbo": "latest"
  }
}
